	(text "There are two supported ways to power the Adalogger.\n\nThe old way is to connect 5V to the USB port using a\nshort \"pig-tail\" cable, connected to a push terminal.\n\nThe new way is to use a 3.3V regulator on the sensor\nboard connected to the 3.3V pin on the Adalogger.\nThis should be safe, but I'm including the old way\njust in case.\n\nTo use the new way, solder JP41 and JP42.\n\nTo use the old way, solder JP43, populate J4 and use the pig-tail."
		(exclude_from_sim no)
		(at 152.908 90.17 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "2e4ddab4-9654-481d-8915-109ba1d632cd")
	)
	(text "5V Regulator"
		(exclude_from_sim no)
		(at 79.756 112.776 0)
		(effects
			(font
				(size 2.5 2.5)
			)
			(justify left)
		)
		(uuid "51b0c881-42a9-468e-afd8-91bfb1786398")
	)
	(text "The Adalogger is powered using the\nUSB micro B connector, connected to J4"
		(exclude_from_sim no)
		(at 93.98 53.34 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "6ba036d4-9cc6-4e7f-9f61-e5d502049607")
	)
	(text "for USB micro-b\nwire with plug"
		(exclude_from_sim no)
		(at 107.95 109.22 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left bottom)

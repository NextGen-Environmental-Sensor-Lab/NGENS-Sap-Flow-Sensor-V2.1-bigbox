	(text "ADDR tied to GND\nAddress 10010000"
		(exclude_from_sim no)
		(at 36.83 81.28 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left bottom)
		)
		(uuid "2160b444-6972-473d-8986-15d60678620c")
	)
	(text "Use A- as GND for the reference,\notherwise noise from the main GND\nwill be added to the ref output"
		(exclude_from_sim no)
		(at 75.184 44.704 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left top)
		)
		(uuid "34e0eb52-aa0d-4469-9f7b-9ba5c242168b")
	)
	(text "Add filter capacitors, as suggested in the datasheet"
		(exclude_from_sim no)
		(at 35.56 101.6 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left top)
		)
		(uuid "508a75f2-88d9-48cc-852b-23b42cab5e19")
	)
	(text "From the East 30 documentation:\n\nBlue - outer thermistor, near needle\nWhite - middle thermistor, near needle\nOrange - inner thermistor, near needle\nPurple - outer thermistor, far needle\nYellow - middle thermistor, far needle\nGreen - inner thermistor, far needle\nRed - thermistor excitation\nPink - common (ground)"
		(exclude_from_sim no)
		(at 197.358 64.77 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left top)
		)
		(uuid "a9f97277-a7df-49d6-9808-7c351c560116")
	)
	(text "J2 has the spare ADC channels, for future use\n\n1 - 2.5V\n2 - A3\n3 - GND\n4 - 2.5V\n5 - A3\n6 - GND"
		(exclude_from_sim no)
		(at 188.722 95.504 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left top)
		)
		(uuid "be8ec10d-9fbe-4907-8523-7e9a23e19b00")
	)
	(text "A- is connnected to GND \nthrough a ferrite bead"
		(exclude_from_sim no)
		(at 139.446 144.018 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left top)
		)
		(uuid "bf77774c-80f9-4824-9bac-b34b2f15c97c")
	)
	(text "2.5V ref"
		(exclude_from_sim no)
		(at 133.35 45.466 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left bottom)
		)
		(uuid "c8ba6458-f634-426c-9985-7e0cf6895a9b")
	)
	(text "Analog filter\nSee section 9.1.5 in ADS1115 datasheet\n\nf_{MOD} = 250 kHz\nR = 10k || 10k = 5k\nWe'll aim for f_{c} = 1 kHz\nC = 33 nF\nf_{MOD} attenuates 48 dB"
		(exclude_from_sim no)
		(at 97.536 161.798 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left top)
		)
		(uuid "e3d11feb-17b7-4b3a-9672-a74a802c5541")
	)

		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "2f35aa0c-1798-4a38-b08f-c4b810607840")
	)
	(text "Near needle\n\nAIN0: Outer\nAIN1: Middle\nAIN2: Inner\nAIN3: Spare"
		(exclude_from_sim no)
		(at 79.756 64.008 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "372dc45d-0f9a-46e2-8b96-dbaaa8235c84")
	)
	(text "2.5V Ref"
		(exclude_from_sim no)
		(at 109.474 19.558 0)
		(effects
			(font
				(size 2.5 2.5)
			)
			(justify left)
		)
		(uuid "45ea80f3-f4f8-4a7d-a7f4-b79371d72921")
	)
	(text "Heater on LED"
		(exclude_from_sim no)
		(at 173.736 116.332 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "464dbb62-7951-47b9-a99b-b5cd1994aedf")
	)
	(text "Load is (10k + 10k) / 6 = 3.33 kOhm\nReference output voltage is 2.5V\nLoad current = 0.83 mA\nTL431 needs 1 mA cathode current for regulation\nCurrent through series resistor must be at least 1.83 mA\nFrom 3.3V supply, voltage drop is 0.8V\nSeries resistor = 430 Ohm\nDecrease to 390 Ohm for headroom"
		(exclude_from_sim no)
		(at 144.78 35.814 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "62d11ca2-5320-4ea9-8815-76b1a90bf77e")
	)
	(text "From the East 30 documentation:\n\nBlue - outer thermistor, near needle\nWhite - middle thermistor, near needle\nOrange - inner thermistor, near needle\nPurple - outer thermistor, far needle\nYellow - middle thermistor, far needle\nGreen - inner thermistor, far needle\nRed - thermistor excitation\nPink - common (ground)"
		(exclude_from_sim no)
		(at 212.598 83.566 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left top)
		)
		(uuid "a9f97277-a7df-49d6-9808-7c351c560116")
	)
	(text "We will try to keep the same colors,\nbut substitutions are necessary\n\nEast 30 uses two black for the heater, \nwe'll use black and brown.\n\nEast 30 has pink, we'll use gray.\n\nThe rest is the same\n\nI think this also makes the connector\nelectrically reversible, as a hedge against\ngetting pin 1 backwards."
		(exclude_from_sim no)
		(at 215.138 124.968 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "c1119f0e-d100-4382-9072-f36b2ce5e892")
	)
	(text "Analog filter\nSee section 9.1.5 in ADS1115 datasheet\n\nf_{MOD} = 250 kHz\nR = 10k || 10k = 5k\nWe'll aim for f_{c} = 1 kHz\nC = 33 nF\nf_{MOD} attenuates 48 dB"
		(exclude_from_sim no)
		(at 77.216 164.338 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left top)
		)
		(uuid "e3d11feb-17b7-4b3a-9672-a74a802c5541")
	)
	(text "Seemingly-standard color order \nfor JST PH 10-pin cable assemblies is\nBlack\nRed\nWhite\nYellow\nOrange\nGreen\nBlue\nPurple\nGray\nBrown\n"
		(exclude_from_sim no)
		(at 152.146 92.964 0)
		(effects
			(font
				(size 1.6 1.6)
			)
			(justify left)
		)
		(uuid "e6f028aa-d57a-44f3-850e-73836493f08b")
	)
	(text "ADDR tied to VDD\nAddress 10010001"
		(exclude_from_sim no)
		(at 21.59 148.336 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left bottom)
		)
		(uuid "fa8ba91a-e1ef-4bef-ade3-a95c6c4203c1")
	)
